@Library('jenkins-shared-library') _

pipeline {
    agent any

    parameters {
        string(name: 'VERSION', defaultValue: '1.0.0', description: 'Image version')
        booleanParam(name: 'ROLLBACK', defaultValue: false, description: 'Rollback?')
    }

    environment {
        SERVICE = 'attendance'
        TEST_DIR = 'Microservices-projects/attendance'
        KUBECONFIG = '/var/lib/jenkins/.kube/config'

        // 🔥 CHANGE THESE
        DEV_URL = 'http://attendance.dev/health'
        STAGING_URL = 'http://attendance.staging/health'
        PROD_URL = 'http://attendance.prod/health'
    }

    stages {

        // 🔔 START
        stage('Start') {
            steps {
                echo "Pipeline Started..."
            }
        }

        // 🏗 BUILD
        stage('Build Image') {
            when { expression { !params.ROLLBACK } }
            steps {
                dir("${TEST_DIR}") {
                    sh """
                        docker build -t attendance:${params.VERSION} .
                    """
                }
            }
        }

        // 🚀 DEV DEPLOY (AUTO)
        stage('Deploy to Dev') {
            when { expression { !params.ROLLBACK } }
            steps {
                sh """
                    kubectl set image deployment/attendance \
                    attendance=attendance:${params.VERSION} -n dev
                    kubectl rollout status deployment/attendance -n dev
                """
            }
        }

        // ✅ DEV TEST
        stage('Test Dev') {
            steps {
                script {
                    def resp = httpRequest(url: "${DEV_URL}", validResponseCodes: '200')
                    echo "Dev Health OK: ${resp.status}"
                }
            }
        }

        // ⏳ APPROVAL
        stage('Approval for Staging') {
            options {
                timeout(time: 30, unit: 'MINUTES')
            }
            steps {
                input message: 'Deploy to Staging?', ok: 'Proceed'
            }
        }

        // 🚀 STAGING DEPLOY
        stage('Deploy to Staging') {
            steps {
                milestone(1)
                sh """
                    kubectl set image deployment/attendance \
                    attendance=attendance:${params.VERSION} -n staging
                    kubectl rollout status deployment/attendance -n staging
                """
            }
        }

        // ✅ STAGING TEST
        stage('Test Staging') {
            steps {
                script {
                    def resp = httpRequest(url: "${STAGING_URL}", validResponseCodes: '200')
                    echo "Staging Health OK: ${resp.status}"
                }
            }
        }

        // 🟢 DEPLOY GREEN (PROD)
        stage('Deploy Green') {
            steps {
                sh """
                    kubectl set image deployment/attendance-green \
                    attendance=attendance:${params.VERSION} -n prod
                    kubectl rollout status deployment/attendance-green -n prod
                """
            }
        }

        // ❤️ HEALTH CHECK
        stage('Health Check Prod') {
            steps {
                retry(3) {
                    sleep 10
                    httpRequest(url: "${PROD_URL}", validResponseCodes: '200')
                }
            }
        }

        // 🔁 SWITCH TRAFFIC
        stage('Switch Traffic to Green') {
            steps {
                sh """
                    kubectl patch svc attendance -n prod \
                    -p '{"spec":{"selector":{"slot":"green"}}}'
                """
            }
        }
    }

    post {

        // ❌ FAILURE → ROLLBACK
        failure {
            echo "Rolling back to BLUE..."

            sh """
                kubectl patch svc attendance -n prod \
                -p '{"spec":{"selector":{"slot":"blue"}}}'
            """
        }

        success {
            echo "Deployment Successful 🚀"
        }

        always {
            echo "Pipeline Completed"
        }
    }
}
