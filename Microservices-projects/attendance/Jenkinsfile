@Library('jenkins-shared-library') _

import org.example.BlueGreenDeployment
import org.example.NotificationManager

// ══════════════════════════════════════════════════════════════
//  Multi-Environment Blue-Green Deployment Pipeline
//  Assignment-5 Complete:
//    ✅ Dev auto-deploy (no approval)
//    ✅ Manual approval for Staging & Prod (input + milestone)
//    ✅ Blue-Green deployment logic for Prod
//    ✅ Health check: kubectl exec → localhost:8081/attendance/healthz
//    ✅ Automatic rollback on health check failure
//    ✅ Milestone for concurrency control
// ══════════════════════════════════════════════════════════════

pipeline {
    agent any

    parameters {
        string(name: 'VERSION',
               defaultValue: '1.0.0',
               description: 'Image version')
        choice(name: 'ENVIRONMENT',
               choices: ['dev', 'staging', 'prod'],
               description: 'Target environment')
        booleanParam(name: 'ROLLBACK',
                     defaultValue: false,
                     description: 'Rollback?')
        string(name: 'RECIPIENTS',
               defaultValue: 'rkrahulsh001@gmail.com',
               description: 'Email recipients')
    }

    environment {
        SERVICE      = 'attendance'
        KUBECONFIG   = '/var/lib/jenkins/.kube/config'
        BRANCH       = "${env.GIT_BRANCH?.replaceAll('origin/', '') ?: 'master'}"
        COVERAGE_MIN = '50'
        TEST_DIR     = 'Microservices-projects/attendance'
        PATH         = "/var/lib/jenkins/.local/bin:${env.PATH}"

        // ✅ Confirmed working health check endpoint
        HEALTH_PORT  = '8081'
        HEALTH_PATH  = '/attendance/healthz'
    }

    stages {

        // ─────────────────────────────────────────────
        // STAGE 1: Notify Start
        // ─────────────────────────────────────────────
        stage('Notify Start') {
            steps {
                script {
                    def nm = new NotificationManager(this)
                    nm.sendSlack('STARTED', buildDetails())
                    nm.sendTeams('STARTED', buildDetails())
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 2: Validate
        // ─────────────────────────────────────────────
        stage('Validate') {
            when { expression { !params.ROLLBACK } }
            steps {
                script {
                    echo "Validating: service=${SERVICE}, env=${params.ENVIRONMENT}, version=${params.VERSION}"
                    echo "Validation passed"
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 3: Setup Test Environment
        // ─────────────────────────────────────────────
        stage('Setup Test Environment') {
            when { expression { !params.ROLLBACK } }
            steps {
                dir("${TEST_DIR}") {
                    sh 'pip3 install -r requirements-test.txt --break-system-packages -q'
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 4: Parallel Tests
        // ─────────────────────────────────────────────
        stage('Parallel Tests') {
            when { expression { !params.ROLLBACK } }
            parallel {

                stage('Unit Tests') {
                    steps {
                        dir("${TEST_DIR}") {
                            catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                                sh """
                                    python3 -m pytest test_unit.py \
                                        -v --tb=short \
                                        --junitxml=unit-results.xml \
                                        --cov=attendance_api \
                                        --cov-report=xml:coverage.xml \
                                        --cov-report=html:coverage-html \
                                        --cov-report=term-missing \
                                        --cov-fail-under=${COVERAGE_MIN} \
                                        2>&1 | tee unit-test.log
                                """
                            }
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: "${TEST_DIR}/unit-results.xml"
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        dir("${TEST_DIR}") {
                            catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                                sh """
                                    python3 -m pytest test_integration.py \
                                        -v --tb=short \
                                        --junitxml=integration-results.xml \
                                        -m integration \
                                        2>&1 | tee integration-test.log
                                """
                            }
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: "${TEST_DIR}/integration-results.xml"
                        }
                    }
                }

                stage('Code Quality') {
                    steps {
                        dir("${TEST_DIR}") {
                            catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                                sh '''
                                    flake8 attendance_api.py \
                                        --max-line-length=120 \
                                        --ignore=E501,W503 \
                                        --tee \
                                        --output-file=flake8-report.txt \
                                        || true
                                    pylint attendance_api.py \
                                        --disable=all \
                                        --enable=E \
                                        --output-format=text \
                                        > pylint-report.txt 2>&1 || true
                                    echo "Code quality done"
                                '''
                            }
                        }
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 5: Coverage Report
        // ─────────────────────────────────────────────
        stage('Coverage Report') {
            when { expression { !params.ROLLBACK } }
            steps {
                dir("${TEST_DIR}") {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        sh """
                            echo "=== Coverage Summary ==="
                            python3 -m coverage report --fail-under=${COVERAGE_MIN} || \
                            echo "WARNING: Coverage below ${COVERAGE_MIN}%"
                        """
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 6: Generate PDF Report
        // ─────────────────────────────────────────────
        stage('Generate PDF Report') {
            when { expression { !params.ROLLBACK } }
            steps {
                dir("${TEST_DIR}") {
                    sh """
                        echo "=== Files before PDF generation ==="
                        ls -la *.xml *.log *.txt 2>/dev/null || true
                        export VERSION=${params.VERSION}
                        export ENVIRONMENT=${params.ENVIRONMENT}
                        export GIT_BRANCH=${env.BRANCH}
                        export BUILD_NUMBER=${env.BUILD_NUMBER}
                        python3 generate_report.py
                        echo "=== PDF Info ==="
                        ls -la test-report.pdf
                    """
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 7: Publish Reports
        // ─────────────────────────────────────────────
        stage('Publish Reports') {
            when { expression { !params.ROLLBACK } }
            steps {
                publishHTML([
                    allowMissing         : true,
                    alwaysLinkToLastBuild: true,
                    keepAll              : true,
                    reportDir            : "${TEST_DIR}/coverage-html",
                    reportFiles          : 'index.html',
                    reportName           : 'Coverage Report'
                ])
                archiveArtifacts(
                    artifacts        : "${TEST_DIR}/test-report.pdf,${TEST_DIR}/*.xml,${TEST_DIR}/*.log,${TEST_DIR}/*.txt",
                    allowEmptyArchive: true,
                    fingerprint      : true
                )
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 8: Deploy to Dev (AUTO — no approval)
        // ─────────────────────────────────────────────
        stage('Deploy to Dev') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    expression { params.ENVIRONMENT == 'dev' }
                    expression { currentBuild.currentResult != 'FAILURE' }
                }
            }
            steps {
                script {
                    echo "=== AUTO DEPLOY to Dev (attendance-blue) — version: ${params.VERSION} ==="
                    sh """
                        kubectl set image deployment/attendance-blue \
                            ${SERVICE}=${SERVICE}:${params.VERSION} \
                            --namespace=dev
                        kubectl rollout status deployment/attendance-blue \
                            --namespace=dev --timeout=120s
                    """
                    echo "Dev deploy complete."
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 9: Test Dev — health check
        //   ✅ port=8081, path=/attendance/healthz
        //   ✅ Sets HEALTH_CHECK_FAILED for auto-rollback
        // ─────────────────────────────────────────────
        stage('Test Dev') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    expression { params.ENVIRONMENT == 'dev' }
                }
            }
            steps {
                script {
                    echo "=== Dev Health Check (port: ${HEALTH_PORT}, path: ${HEALTH_PATH}) ==="
                    sleep(time: 10, unit: 'SECONDS')
                    def result = sh(
                        script: """
                            POD=\$(kubectl get pod -n dev \
                                -l app=attendance,slot=blue \
                                --field-selector=status.phase=Running \
                                -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
                            if [ -z "\$POD" ]; then
                                echo "WARNING: No running pod found in dev"
                                exit 1
                            fi
                            echo "Checking pod: \$POD"
                            kubectl exec -n dev "\$POD" -- \
                                curl -sf --connect-timeout 10 \
                                http://localhost:${HEALTH_PORT}${HEALTH_PATH}
                        """,
                        returnStatus: true
                    )
                    if (result != 0) {
                        // ✅ Auto-rollback trigger: set flag + rollback immediately
                        env.HEALTH_CHECK_FAILED = 'true'
                        env.FAILED_NAMESPACE    = 'dev'
                        echo "❌ Dev health check FAILED — triggering auto-rollback"
                        // Rollback dev deployment to previous revision
                        sh """
                            echo "=== AUTO-ROLLBACK: Dev ==="
                            kubectl rollout undo deployment/attendance-blue --namespace=dev
                            kubectl rollout status deployment/attendance-blue \
                                --namespace=dev --timeout=120s
                            echo "Dev rollback complete."
                        """
                        currentBuild.result = 'FAILURE'
                        error("Dev health check failed — rolled back and aborting pipeline")
                    } else {
                        env.HEALTH_CHECK_FAILED = 'false'
                        echo "✅ Dev health check PASSED."
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 10: Manual Approval — Staging / Prod
        //   milestone(1) → input → milestone(2)
        //   ✅ Concurrency control via milestone
        // ─────────────────────────────────────────────
        stage('Approval for Staging / Prod') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    anyOf {
                        expression { params.ENVIRONMENT == 'staging' }
                        expression { params.ENVIRONMENT == 'prod' }
                    }
                    expression { currentBuild.currentResult != 'FAILURE' }
                }
            }
            steps {
                script {
                    // ✅ milestone: if newer build reaches here, older build is cancelled
                    milestone ordinal: 1

                    input message: "Deploy ${SERVICE}:${params.VERSION} to ${params.ENVIRONMENT} ?",
                          ok: "Yes, Deploy!"

                    milestone ordinal: 2
                    echo "Approved. Deploying to ${params.ENVIRONMENT}..."
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 11: Deploy to Staging
        // ─────────────────────────────────────────────
        stage('Deploy to Staging') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    expression { params.ENVIRONMENT == 'staging' }
                    expression { currentBuild.currentResult != 'FAILURE' }
                }
            }
            steps {
                script {
                    echo "=== Deploying to Staging — version: ${params.VERSION} ==="
                    sh """
                        kubectl set image deployment/attendance-blue \
                            ${SERVICE}=${SERVICE}:${params.VERSION} \
                            --namespace=staging
                        kubectl rollout status deployment/attendance-blue \
                            --namespace=staging --timeout=120s
                    """
                    echo "Staging deploy complete."
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 12: Test Staging — health check
        //   ✅ port=8081, path=/attendance/healthz
        //   ✅ Auto-rollback on failure (undo deployment)
        // ─────────────────────────────────────────────
        stage('Test Staging') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    expression { params.ENVIRONMENT == 'staging' }
                }
            }
            steps {
                script {
                    echo "=== Staging Health Check (port: ${HEALTH_PORT}, path: ${HEALTH_PATH}) ==="
                    sleep(time: 15, unit: 'SECONDS')
                    def result = sh(
                        script: """
                            POD=\$(kubectl get pod -n staging \
                                -l app=attendance,slot=blue \
                                --field-selector=status.phase=Running \
                                -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
                            if [ -z "\$POD" ]; then
                                echo "WARNING: No running pod found in staging"
                                exit 1
                            fi
                            echo "Checking pod: \$POD"
                            kubectl exec -n staging "\$POD" -- \
                                curl -sf --connect-timeout 10 \
                                http://localhost:${HEALTH_PORT}${HEALTH_PATH}
                        """,
                        returnStatus: true
                    )
                    if (result != 0) {
                        // ✅ Auto-rollback: undo the staging deployment
                        env.HEALTH_CHECK_FAILED = 'true'
                        env.FAILED_NAMESPACE    = 'staging'
                        echo "❌ Staging health check FAILED — triggering auto-rollback"
                        sh """
                            echo "=== AUTO-ROLLBACK: Staging ==="
                            kubectl rollout undo deployment/attendance-blue --namespace=staging
                            kubectl rollout status deployment/attendance-blue \
                                --namespace=staging --timeout=120s
                            echo "Staging rollback complete. Previous version restored."
                        """
                        currentBuild.result = 'FAILURE'
                        error("Staging health check failed — rolled back and aborting pipeline")
                    } else {
                        env.HEALTH_CHECK_FAILED = 'false'
                        echo "✅ Staging health check PASSED."
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 13: Blue-Green Deploy to Prod (idle slot)
        //   ✅ Finds live slot dynamically
        //   ✅ Deploys to idle slot — live slot unchanged
        // ─────────────────────────────────────────────
        stage('Deploy to Green (Prod Blue-Green)') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    expression { params.ENVIRONMENT == 'prod' }
                    expression { currentBuild.currentResult != 'FAILURE' }
                }
            }
            steps {
                script {
                    echo "=== Blue-Green: Finding idle slot ==="

                    def liveSlot = sh(
                        script: "kubectl get svc ${SERVICE} -n prod -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'blue'",
                        returnStdout: true
                    ).trim()

                    def idleSlot = (liveSlot == 'blue') ? 'green' : 'blue'
                    echo "Live: ${liveSlot} | Deploying to idle: ${idleSlot}"

                    env.LIVE_SLOT = liveSlot
                    env.IDLE_SLOT = idleSlot

                    sh """
                        kubectl set image deployment/${SERVICE}-${idleSlot} \
                            ${SERVICE}=${SERVICE}:${params.VERSION} \
                            -n prod
                        kubectl rollout status deployment/${SERVICE}-${idleSlot} \
                            -n prod --timeout=120s
                    """
                    echo "Deployed ${params.VERSION} to ${idleSlot} slot. ${liveSlot} still serving traffic."
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 14: Health Check — idle slot (5 retries)
        //   ✅ port=8081, path=/attendance/healthz
        //   ✅ Sets HEALTH_CHECK_FAILED for Rollback stage
        // ─────────────────────────────────────────────
        stage('Health Check - Green Slot') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    expression { params.ENVIRONMENT == 'prod' }
                }
            }
            steps {
                script {
                    def idleSlot = env.IDLE_SLOT
                    echo "=== Health Check on idle slot: ${idleSlot} (port: ${HEALTH_PORT}, path: ${HEALTH_PATH}) ==="
                    sleep(time: 15, unit: 'SECONDS')

                    def passed = false
                    for (int i = 1; i <= 5; i++) {
                        def result = sh(
                            script: """
                                POD=\$(kubectl get pod -n prod \
                                    -l app=${SERVICE},slot=${idleSlot} \
                                    --field-selector=status.phase=Running \
                                    -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
                                if [ -z "\$POD" ]; then
                                    echo "Attempt ${i}: No running pod for slot ${idleSlot}"
                                    exit 1
                                fi
                                echo "Attempt ${i}: Checking pod \$POD"
                                kubectl exec -n prod "\$POD" -- \
                                    curl -sf --connect-timeout 10 \
                                    http://localhost:${HEALTH_PORT}${HEALTH_PATH}
                            """,
                            returnStatus: true
                        )
                        if (result == 0) {
                            echo "✅ Health check attempt ${i}/5: PASSED"
                            passed = true
                            break
                        }
                        echo "❌ Health check attempt ${i}/5: FAILED"
                        if (i < 5) { sleep(time: 10, unit: 'SECONDS') }
                    }

                    if (!passed) {
                        env.HEALTH_CHECK_FAILED = 'true'
                        echo "❌ Health check FAILED after 5 attempts — Rollback stage will execute."
                        // Don't switch traffic — Rollback stage keeps live slot active
                        currentBuild.result = 'UNSTABLE'
                    } else {
                        env.HEALTH_CHECK_FAILED = 'false'
                        echo "✅ Health check PASSED. Ready to switch traffic."
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 15: Switch Traffic → idle slot goes live
        //   Only runs if HEALTH_CHECK_FAILED == 'false'
        // ─────────────────────────────────────────────
        stage('Switch Traffic to Green') {
            when {
                allOf {
                    expression { !params.ROLLBACK }
                    expression { params.ENVIRONMENT == 'prod' }
                    expression { env.HEALTH_CHECK_FAILED == 'false' }
                }
            }
            steps {
                script {
                    echo "=== Switching traffic: ${env.LIVE_SLOT} → ${env.IDLE_SLOT} ==="
                    sh """
                        kubectl patch svc ${SERVICE} -n prod \
                            --type=json \
                            -p '[{"op":"replace","path":"/spec/selector/slot","value":"${env.IDLE_SLOT}"}]'
                    """
                    echo "✅ Traffic switched! ${env.IDLE_SLOT} is now LIVE. ${env.LIVE_SLOT} is standby."
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 16: Rollback
        //   Triggers when:
        //     A) params.ROLLBACK = true  (manual rollback)
        //     B) HEALTH_CHECK_FAILED = 'true' (auto-rollback after prod health failure)
        //
        //   Prod:    service selector stays on LIVE_SLOT (no switch happened)
        //            idle slot image reverted via kubectl rollout undo
        //   Staging: kubectl rollout undo (handled in Test Staging stage itself)
        //   Manual:  switches svc selector to other slot
        // ─────────────────────────────────────────────
        stage('Rollback') {
            when {
                anyOf {
                    expression { params.ROLLBACK }
                    expression { env.HEALTH_CHECK_FAILED == 'true' }
                }
            }
            steps {
                script {
                    if (params.ROLLBACK) {
                        // ── Manual rollback ──────────────────────────────
                        def ns = params.ENVIRONMENT
                        echo "=== MANUAL ROLLBACK on ${ns} ==="
                        sh """
                            LIVE=\$(kubectl get svc ${SERVICE} -n ${ns} \
                                -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'blue')
                            PREV=\$([ "\$LIVE" = "blue" ] && echo "green" || echo "blue")
                            echo "Switching back to: \$PREV"
                            kubectl patch svc ${SERVICE} -n ${ns} \
                                --type=json \
                                -p '[{"op":"replace","path":"/spec/selector/slot","value":"'"\$PREV"'"}]'
                            echo "Manual rollback complete. \$PREV is now live."
                        """

                    } else {
                        // ── Auto-rollback after prod health check failure ─
                        def liveSlot = env.LIVE_SLOT
                        def idleSlot = env.IDLE_SLOT
                        echo "=== AUTO-ROLLBACK: Prod health check failed ==="
                        echo "Traffic was never switched — ${liveSlot} is still serving."
                        echo "Reverting ${idleSlot} slot image to previous revision..."
                        sh """
                            kubectl rollout undo deployment/${SERVICE}-${idleSlot} -n prod
                            kubectl rollout status deployment/${SERVICE}-${idleSlot} \
                                -n prod --timeout=120s

                            echo ""
                            echo "=== Rollback Summary ==="
                            echo "Live slot (unchanged): ${liveSlot}"
                            echo "Idle slot reverted:    ${idleSlot}"
                            kubectl get svc ${SERVICE} -n prod \
                                -o jsonpath='Service selector slot: {.spec.selector.slot}'
                            echo ""
                        """
                        echo "✅ Auto-rollback complete. ${liveSlot} continues serving traffic."
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 17: Final Status
        // ─────────────────────────────────────────────
        stage('Final Status') {
            steps {
                script {
                    echo "=== FINAL STATUS ==="
                    sh "kubectl get all -n ${params.ENVIRONMENT} || true"
                    def liveSlot = sh(
                        script: "kubectl get svc ${SERVICE} -n ${params.ENVIRONMENT} -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'N/A'",
                        returnStdout: true
                    ).trim()
                    def blueImg = sh(
                        script: "kubectl get deployment ${SERVICE}-blue -n ${params.ENVIRONMENT} -o jsonpath='{.spec.template.spec.containers[0].image}' 2>/dev/null || echo 'N/A'",
                        returnStdout: true
                    ).trim()
                    def greenImg = sh(
                        script: "kubectl get deployment ${SERVICE}-green -n ${params.ENVIRONMENT} -o jsonpath='{.spec.template.spec.containers[0].image}' 2>/dev/null || echo 'N/A'",
                        returnStdout: true
                    ).trim()
                    echo ""
                    echo "=== LIVE SLOT  === ${liveSlot}"
                    echo "=== BLUE  IMG  === ${blueImg}"
                    echo "=== GREEN IMG  === ${greenImg}"
                }
            }
        }
    }

    // ─────────────────────────────────────────────────
    // POST ACTIONS
    //   ✅ Auto-rollback safety net for prod on FAILURE
    //      (catches unexpected failures before Rollback stage)
    // ─────────────────────────────────────────────────
    post {
        always {
            echo "=== POST: ALWAYS ==="
            echo "Build: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            echo "Duration: ${currentBuild.durationString}"
            echo "Status: ${currentBuild.currentResult}"
        }

        success {
            script {
                echo "=== POST: SUCCESS ==="
                def nm = new NotificationManager(this)
                nm.sendSlack('SUCCESS', buildDetails())
                nm.sendTeams('SUCCESS', buildDetails())
                emailext(
                    subject           : "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body              : buildEmailBody('SUCCESS'),
                    mimeType          : 'text/html',
                    to                : params.RECIPIENTS,
                    attachmentsPattern: "${TEST_DIR}/test-report.pdf"
                )
            }
        }

        failure {
            script {
                echo "=== POST: FAILURE ==="
                // ✅ Safety net: if prod failed unexpectedly after traffic may have
                //    switched, revert selector back to original live slot
                if (params.ENVIRONMENT == 'prod' && env.LIVE_SLOT) {
                    echo "=== POST AUTO-ROLLBACK SAFETY NET: Prod → reverting to ${env.LIVE_SLOT} ==="
                    sh """
                        kubectl patch svc ${SERVICE} -n prod \
                            --type=json \
                            -p '[{"op":"replace","path":"/spec/selector/slot","value":"${env.LIVE_SLOT}"}]' \
                            || true
                        echo "Service selector restored to: ${env.LIVE_SLOT}"
                    """
                }
                def nm = new NotificationManager(this)
                nm.sendSlack('FAILURE', buildDetails())
                nm.sendTeams('FAILURE', buildDetails())
                emailext(
                    subject           : "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body              : buildEmailBody('FAILURE'),
                    mimeType          : 'text/html',
                    to                : params.RECIPIENTS,
                    attachLog         : true,
                    attachmentsPattern: "${TEST_DIR}/test-report.pdf"
                )
            }
        }

        unstable {
            script {
                echo "=== POST: UNSTABLE ==="
                def nm = new NotificationManager(this)
                nm.sendSlack('UNSTABLE', buildDetails())
                emailext(
                    subject           : "UNSTABLE: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body              : buildEmailBody('UNSTABLE'),
                    mimeType          : 'text/html',
                    to                : params.RECIPIENTS,
                    attachmentsPattern: "${TEST_DIR}/test-report.pdf"
                )
            }
        }
    }
}

// ─────────────────────────────────────────────────────
// HELPER FUNCTIONS
// ─────────────────────────────────────────────────────
def buildDetails() {
    def changesList = []
    try {
        currentBuild.changeSets.each { cs ->
            cs.items.each { item ->
                changesList << "${item.author}: ${item.msg}"
            }
        }
    } catch (e) {
        changesList << 'No changes info'
    }
    return [
        jobName    : env.JOB_NAME,
        buildNumber: env.BUILD_NUMBER,
        branch     : env.BRANCH ?: 'master',
        service    : SERVICE,
        version    : params.VERSION,
        environment: params.ENVIRONMENT,
        duration   : currentBuild.durationString ?: 'N/A',
        changes    : changesList.isEmpty() ? 'No changes' : changesList.join(' | '),
        buildUrl   : env.BUILD_URL,
        recipients : params.RECIPIENTS
    ]
}

def buildEmailBody(String status) {
    def color    = (status == 'SUCCESS') ? '#28a745' :
                   (status == 'FAILURE') ? '#dc3545' : '#ffc107'
    def liveInfo = env.LIVE_SLOT ?: 'N/A'
    return """
<!DOCTYPE html><html><body style="font-family:Arial,sans-serif;padding:20px;">
<div style="background:${color};padding:15px;border-radius:8px;margin-bottom:20px;">
  <h2 style="color:white;margin:0;">${status}: ${env.JOB_NAME} #${env.BUILD_NUMBER}</h2>
</div>
<table style="width:100%;border-collapse:collapse;">
  <tr style="background:#f2f2f2;">
    <td style="padding:8px;border:1px solid #ddd;font-weight:bold;">Service</td>
    <td style="padding:8px;border:1px solid #ddd;">${SERVICE}</td></tr>
  <tr><td style="padding:8px;border:1px solid #ddd;font-weight:bold;">Version</td>
    <td style="padding:8px;border:1px solid #ddd;">${params.VERSION}</td></tr>
  <tr style="background:#f2f2f2;">
    <td style="padding:8px;border:1px solid #ddd;font-weight:bold;">Environment</td>
    <td style="padding:8px;border:1px solid #ddd;">${params.ENVIRONMENT}</td></tr>
  <tr><td style="padding:8px;border:1px solid #ddd;font-weight:bold;">Branch</td>
    <td style="padding:8px;border:1px solid #ddd;">${env.BRANCH}</td></tr>
  <tr style="background:#f2f2f2;">
    <td style="padding:8px;border:1px solid #ddd;font-weight:bold;">Duration</td>
    <td style="padding:8px;border:1px solid #ddd;">${currentBuild.durationString}</td></tr>
  <tr><td style="padding:8px;border:1px solid #ddd;font-weight:bold;">Live Slot</td>
    <td style="padding:8px;border:1px solid #ddd;">${liveInfo}</td></tr>
  <tr style="background:#f2f2f2;">
    <td style="padding:8px;border:1px solid #ddd;font-weight:bold;">Build URL</td>
    <td style="padding:8px;border:1px solid #ddd;"><a href="${env.BUILD_URL}">View Logs</a></td></tr>
</table>
<p style="margin-top:15px;padding:10px;background:#f8f9fa;border-radius:5px;">
  Test Report PDF attached. Coverage HTML report available in Jenkins.
</p>
</body></html>
    """
}
